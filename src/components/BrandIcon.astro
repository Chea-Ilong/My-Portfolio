---
interface Props {
  name: 'github' | 'linkedin';
  class?: string;
}

const { name, class: className } = Astro.props;
---

<svg
  class={className}
  xmlns="http://www.w3.org/2000/svg"
  width="24"
  height="24"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {name === 'github' ? (
    <>
      <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3.28 0 6.72-.82 6.72-5a3.89 3.89 0 0 0-1.08-2.7 3.56 3.56 0 0 0-.1-2.7s-.84-.27-2.75 1.07a9.64 9.64 0 0 0-5 0C9.16 3.83 8.32 4.1 8.32 4.1a3.56 3.56 0 0 0-.1 2.7A3.89 3.89 0 0 0 7.14 9.5c0 4.18 3.44 5 6.72 5A4.8 4.8 0 0 0 13 18v4" />
      <path d="M9 18c-4.51 2-5-2-7-2" />
    </>
  ) : (
    <>
      <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
      <rect width="4" height="12" x="2" y="9" />
      <circle cx="4" cy="4" r="2" />
    </>
  )}
</svg>
